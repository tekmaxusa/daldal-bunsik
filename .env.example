# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Ordering (optional; add to .env for production) ---
# WhatsApp: country code + number, digits only (US example: 19725551234 = +1 972-555-1234).
# Enables "Send order on WhatsApp" on /order with the customer's cart filled in.
# VITE_ORDER_WHATSAPP="19725551234"

# When set, ORDER / Cart buttons open this URL in a new tab (internal /order page stays hidden).
# VITE_ONLINE_ORDER_URL="https://your-ordering-link.example"

# Google Apps Script “order → email” endpoint (see google-apps-script-order.example.js in this repo).
# Same idea as https://github.com/tekmaxusa/changehair-beauty — deploy as Web app (Anyone), paste URL here.
# VITE_GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# --- Google Maps (optional — opens your Business Profile instead of a bare address pin) ---
# In Google Maps, open your verified listing → Share → copy link (maps.app.goo.gl or maps?cid=…).
# VITE_GOOGLE_MAPS_PLACE_URL="https://maps.app.goo.gl/your-short-link"
# Or set Place ID (ChIJ…) if you have it from Google Places / Business Profile tools:
# VITE_GOOGLE_MAPS_PLACE_ID="ChIJxxxxxxxxxxxxxxxx"
# Optional: same listing → Share → Embed a map → copy only the iframe src URL (contains …embed?pb=…):
# VITE_GOOGLE_MAPS_EMBED_SRC="https://www.google.com/maps/embed?pb=!1m18!1m12!..."
